    "karma-mocha": "^2.0.1",
    "karma-phantomjs-launcher": "^1.0.4",
    "karma-webpack": "^5.0.1",
    "mocha": "^11.7.6",
    "process": "^0.11.10",
    "webpack": "^5.69.0",

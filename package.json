    "url": "https://github.com/dejaneves/checkforce.js/issues"
  },
  "homepage": "https://github.com/dejaneves/checkforce.js#readme",
  "peerDependencies": {
    "@popperjs/core": "^2.11.2",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@babel/core": "^7.17.4",
    "@babel/preset-env": "^7.16.11",
    "@popperjs/core": "^2.11.2",
    "assert": "^2.1.0",
    "babel-loader": "^8.2.3",
    "chai": "^6.2.2",
    "jasmine-core": "^6.3.0",
    "karma": "^6.4.4",
    "karma-chai": "^0.1.0",
    "karma-chrome-launcher": "^3.2.0",
